# ─── 사내 MySQL / MariaDB 접속 정보 ───────────────────────────────────────────
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워주세요.
#   cp .env.example .env

DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CHARSET=utf8mb4

# ─── 수집 기본값 ──────────────────────────────────────────────────────────────
# 시계열 수집 시작일 (YYYY-MM-DD). 비워두면 DB 최초 데이터 기준 자동 결정
COLLECT_START_DATE=

# 시계열 수집 종료일 (YYYY-MM-DD). 비워두면 오늘 날짜까지 수집
COLLECT_END_DATE=

# 한 번에 fetch 할 날짜 범위 (일). 대용량 DB 에서 메모리 초과 방지
COLLECT_BATCH_DAYS=30

# ─── 출력 경로 ────────────────────────────────────────────────────────────────
# 비워두면 스크립트 기준 ../../project/artifacts/dataset_snapshot 사용
OUTPUT_DIR=
