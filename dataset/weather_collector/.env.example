# ─── 기상청 / 공공데이터포털 API 키 ──────────────────────────────────────────
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워주세요.
#   cp .env.example .env
#
# ❶ 단기예보·초단기예보·일출몰 API
#    발급처: https://www.data.go.kr (공공데이터포털)
#    서비스: 기상청_단기예보 ((구)동네예보) 조회서비스
#    ※ URL 인코딩된 키를 그대로 붙여넣으면 자동으로 디코딩됩니다.
KMA_API_KEY=8fsu6XbEIR2%2FTjMWUjVqFzwHaCvbImmfl%2F3qxIqx8CGQirKOh7WTMkZvk1yla9JPTWQwVdP41XN28t2scncceQ%3D%3D

# ❷ ASOS 시간 관측 API
#    발급처: https://www.data.go.kr (공공데이터포털)
#    서비스: 기상청_지상(종관, ASOS) 시간자료 조회서비스
#    ※ 공공데이터포털 키는 KMA_API_KEY와 동일 키를 사용할 수 있습니다.
ASOS_API_KEY=8fsu6XbEIR2%2FTjMWUjVqFzwHaCvbImmfl%2F3qxIqx8CGQirKOh7WTMkZvk1yla9JPTWQwVdP41XN28t2scncceQ%3D%3D

# ❸ AWS 방재기상관측 시간통계 API  ← 없으면 AWS 수집을 건너뜁니다
#    발급처: https://apihub.kma.go.kr (기상청 API허브, 공공데이터포털과 별도)
#    서비스: 지상관측 → 방재기상관측(AWS) → 시간통계 자료 조회 (awsh.php)
#    ※ 미입력 시 'python run.py aws' 및 'python run.py all' 에서 AWS 단계를 건너뜁니다.
APIHUB_KEY=

# ❹ ECMWF CDS API 키 (ERA5 재분석 수집 — 전략 B 학습용 NWP 입력)
#    발급처: https://cds.climate.copernicus.eu  (무료 계정 필요)
#    위치:   로그인 후 우상단 프로필 → API key 복사
#    형식:   <UID>:<API-KEY>  (예: 12345:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
#    대안:   ~/.cdsapirc 파일에 직접 설정해도 됨 (아래 형식)
#            url: https://cds.climate.copernicus.eu/api
#            key: <UID>:<API-KEY>
#    ※ 미입력 시 ~/.cdsapirc 를 자동으로 시도합니다.
CDS_API_KEY=
CDS_API_URL=https://cds.climate.copernicus.eu/api

# ─── 수집 기본값 ──────────────────────────────────────────────────────────────
# ASOS/AWS 관측 이력 수집 시작일 (YYYY-MM-DD). 비워두면 2022-01-01 사용
OBS_START_DATE=

# ASOS/AWS 관측 이력 수집 종료일 (YYYY-MM-DD). 비워두면 오늘 날짜
OBS_END_DATE=

# 관측 배치 단위 일수 (API rate limit 고려). 기본 30
OBS_BATCH_DAYS=30

# ─── 출력 경로 ────────────────────────────────────────────────────────────────
# 비워두면 ../../project/artifacts/dataset_snapshot 사용
OUTPUT_DIR=
